<view class="wrap">
  <view class="card">
    <h2>我的店铺</h2>
    <text class="muted">你创建的店铺会出现在这里，创建后即成为 owner。</text>
    <view class="btn" bindtap="goCreate">+ 创建店铺</view>
  </view>

  <view class="card" wx:if="{{shops.length}}">
    <h2>已有店铺</h2>
    <view class="row" wx:for="{{shops}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view>
        <view style="font-weight:700">{{item.name}}</view>
        <text class="muted">WiFi：{{item.wifiSsid}}</text>
      </view>
      <text class="muted">进入 ›</text>
    </view>
  </view>

  <view class="card" wx:elif="{{!loading}}">
    <text class="muted">还没有店铺，点上方按钮创建第一个。</text>
  </view>
</view>
