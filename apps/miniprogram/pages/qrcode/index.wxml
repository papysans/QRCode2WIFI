<view class="wrap" wx:if="{{qr}}">
  <view class="page-head">
    <view class="mark">门店二维码</view>
    <view class="pill blue">已生成</view>
  </view>

  <view class="card qr-card">
    <h2>{{shop.name}} 专属二维码</h2>
    <view class="qr-frame">
      <image src="{{qr.imageUrl}}" class="qr-img" mode="aspectFit" />
    </view>
    <view class="qr-path">
      <text class="muted">扫码路径</text>
      <text class="path-v">{{qr.path}}</text>
    </view>
    <view class="btn ghost btn-hover" hover-class="btn-hover" bindtap="copyLink">复制店铺链接</view>
    <text class="muted tip">二维码只携带 sid，不含明文密码，顾客扫码后只进入本店连接页。</text>
  </view>
</view>
