<view class="wrap" wx:if="{{qr}}">
  <view class="card" style="text-align:center">
    <h2>{{shop.name}} 专属二维码</h2>
    <image src="{{qr.imageUrl}}" style="width:360rpx;height:360rpx;margin:24rpx auto" mode="aspectFit" />
    <text class="muted">扫码路径：{{qr.path}}</text>
    <view class="btn ghost" bindtap="copyLink">复制店铺链接</view>
    <text class="muted" style="display:block;margin-top:16rpx">二维码只携带 sid，不含明文密码。</text>
  </view>
</view>
