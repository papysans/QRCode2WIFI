.qr-card {
  text-align: center;
}
.qr-frame {
  width: 420rpx;
  height: 420rpx;
  margin: 28rpx auto 20rpx;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #d9d0c2;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(43, 34, 20, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.qr-img {
  width: 100%;
  height: 100%;
}
.qr-path {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 6rpx;
}
.path-v {
  font-size: 26rpx;
  color: #2c5079;
  font-weight: 600;
  word-break: break-all;
}
.tip {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
}
