.error-card {
  border-color: #eccabc;
  background: #f8e5dd;
}
.store-card {
  text-align: center;
  background: linear-gradient(160deg, #fffefb, #f6f0e3);
}
.store-logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 18rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #158474, #8bd0c1);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 0 12rpx;
  box-shadow: 0 12rpx 26rpx rgba(21, 132, 116, 0.22);
}
.store-name {
  font-size: 38rpx;
}
.ssid-box {
  margin-top: 22rpx;
  padding: 22rpx 26rpx;
  border-radius: 20rpx;
  border: 1rpx solid #ddd3c4;
  background: #fbf9f4;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ssid-v {
  font-weight: 700;
  color: var(--ink);
  font-size: 30rpx;
}
.btn-hero {
  padding: 32rpx;
  font-size: 34rpx;
}
