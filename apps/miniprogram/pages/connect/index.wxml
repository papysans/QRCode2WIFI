<view class="wrap">
  <view class="card error-card" wx:if="{{error}}">
    <h2>无法连接</h2>
    <text class="muted">{{error}}</text>
  </view>

  <block wx:if="{{shop}}">
    <view class="page-head">
      <view class="mark">当前门店</view>
      <view class="pill">免费 WiFi</view>
    </view>

    <view class="card store-card">
      <view class="store-logo">{{shop.name}}</view>
      <h2 class="store-name">{{shop.name}}</h2>
      <text class="lead">你正在连接本店免费 WiFi，看完广告即可一键连接。</text>
      <view class="ssid-box">
        <text class="muted">WiFi 名称</text>
        <text class="ssid-v">{{shop.wifiSsid}}</text>
      </view>
    </view>

    <view class="btn amber btn-hero btn-hover" hover-class="btn-hover" bindtap="watchAd">看广告连 WiFi</view>

    <view class="card" wx:if="{{shop.reviewLink || shop.groupBuyLink}}">
      <h2>店铺推荐</h2>
      <view class="row" wx:if="{{shop.reviewLink}}" data-url="{{shop.reviewLink}}" bindtap="openLink" hover-class="btn-hover">
        <text class="muted">大众点评</text><text class="v">复制打开 ›</text>
      </view>
      <view class="row" wx:if="{{shop.groupBuyLink}}" data-url="{{shop.groupBuyLink}}" bindtap="openLink" hover-class="btn-hover">
        <text class="muted">美团团购</text><text class="v">复制打开 ›</text>
      </view>
    </view>
  </block>
</view>
