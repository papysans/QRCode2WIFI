page {
  --teal: #158474;
  --amber: #bf8425;
  --ink: #1d292d;
  --muted: #66757b;
  background: #f4f0e7;
  color: var(--ink);
  font-family: -apple-system, "PingFang SC", sans-serif;
}
.wrap { padding: 24rpx; }
.card {
  background: #fff;
  border: 1rpx solid #e5dccf;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.card h2 { font-size: 32rpx; margin: 0 0 16rpx; }
.muted { color: var(--muted); font-size: 26rpx; }
.row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #f0ead f;
}
.field { margin-bottom: 20rpx; }
.field .label { font-size: 26rpx; color: var(--muted); margin-bottom: 8rpx; }
.input {
  border: 1rpx solid #ddd3c4; border-radius: 16rpx;
  padding: 18rpx 20rpx; background: #fbf9f4; font-size: 28rpx;
}
.btn {
  background: linear-gradient(90deg, var(--teal), #38a895);
  color: #fff; border-radius: 999rpx; text-align: center;
  padding: 24rpx; font-size: 30rpx; font-weight: 700; margin-top: 16rpx;
}
.btn.amber { background: linear-gradient(90deg, var(--amber), #d8a53e); }
.btn.ghost { background: #26363b; }
