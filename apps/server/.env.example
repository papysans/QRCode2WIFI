# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/q2w?schema=public"
# Redis
REDIS_URL="redis://localhost:6379"
# JWT
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
# WiFi 密码加密密钥（32 字节 hex，生产务必更换）
WIFI_ENC_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# 适配层模式：mock | wechat
ADAPTER_MODE="mock"
# 广告预估 eCPM 默认值（元 / 千次完成），也可在 Setting 表覆盖
DEFAULT_ECPM="30"
# 本地 Logo 上传目录
UPLOAD_DIR="./uploads"
PORT="3000"
