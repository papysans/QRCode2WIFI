# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/q2w?schema=public"
# Redis
REDIS_URL="redis://localhost:6379"
# JWT
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
# WiFi 密码加密密钥（32 字节 hex，生产务必更换）
WIFI_ENC_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# 适配层模式：mock | wechat
ADAPTER_MODE="mock"
# 微信小程序 AppID（服务端专用，切勿下发客户端）
WX_APPID=
# 微信小程序 AppSecret（服务端专用密钥，切勿下发客户端）
WX_SECRET=
# 激励视频广告位 ID（小程序客户端使用，需开通流量主）
AD_UNIT_ID=
# 激励视频「服务器回调」签名密钥（MP 后台为广告位配置，用于回调验签）
WX_AD_CALLBACK_TOKEN=
# 小程序码目标页（已发布、无前导斜杠、无 query）
WX_CONNECT_PAGE=pages/connect/index
# 小程序码环境版本：release | trial | develop
WX_ENV_VERSION=release
# 广告预估 eCPM 默认值（元 / 千次完成），也可在 Setting 表覆盖
DEFAULT_ECPM="30"
# 本地 Logo 上传目录
UPLOAD_DIR="./uploads"
PORT="3000"
